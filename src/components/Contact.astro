---
import { asset } from '../utils';
---

<section id="contact" class="bg-lotg-dark py-20 px-4 md:px-8 lg:px-16">
  <div class="max-w-4xl mx-auto text-center">

    <h2 class="font-bangers text-lotg-green text-6xl md:text-8xl tracking-wider text-outline-lg leading-none mb-3">
      Say Hello
    </h2>
    <p class="text-lotg-yellow text-lg tracking-wide mb-12">Questions · Social · Get Involved</p>

    <!-- Social links -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-5 mb-14">

      <!-- Instagram -->
      <a
        href="https://instagram.com/l0st_in_the_grass"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-3 bg-lotg-card border border-lotg-green/30 rounded-full px-7 py-3.5 hover:border-lotg-green hover:bg-lotg-green/10 transition-all duration-200 group"
      >
        <img
          src={asset('icons_social/Instagram-Logo.wine.png')}
          alt="Instagram"
          class="w-6 h-6 object-contain"
        />
        <span class="font-bangers text-xl text-lotg-offwhite tracking-wide group-hover:text-lotg-green transition-colors">
          @l0st_in_the_grass
        </span>
      </a>

    </div>

    <!-- Get involved callout -->
    <div class="bg-lotg-mid rounded-2xl p-8 border border-lotg-green/30 mb-14">
      <h3 class="font-bangers text-lotg-yellow text-3xl tracking-wide mb-3">Get Involved</h3>
      <p class="text-lotg-offwhite text-lg mb-5">
        Want to DJ or perform? Got a question?
      </p>
      <a
        href="https://instagram.com/l0st_in_the_grass"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 bg-lotg-green text-lotg-dark px-7 py-3 rounded-full text-lg font-bold uppercase hover:bg-lotg-yellow transition-colors"
      >
        DM Us on Instagram
      </a>
    </div>

    <!-- Hosted by -->
    <div class="flex flex-col items-center gap-4 mb-10">
      <p class="text-lotg-offwhite/40 text-xs uppercase tracking-widest">Hosted by</p>
      <a href="https://www.outtograss.com" target="_blank" rel="noopener" class="opacity-70 hover:opacity-100 transition-opacity">
        <img
          src={asset('logo_venue_farm/otg-logo.png')}
          alt="Out to Grass"
          class="h-12"
          loading="lazy"
        />
      </a>
      <p class="text-lotg-offwhite/40 text-sm">
        Out to Grass, Woodend Farm, Bromyard Rd, Malvern, WR13 5JW
      </p>
    </div>

    <!-- Footer -->
    <div class="border-t border-lotg-green/10 pt-8 space-y-2">
      <img
        src={asset('logo/website_logo.png')}
        alt="Lost in the Grass"
        class="h-12 mx-auto opacity-80"
        loading="lazy"
      />
      <p class="text-lotg-offwhite/30 text-xs tracking-wider">
        © 2026 Echofields · Lost in the Grass · All rights reserved
      </p>
    </div>

  </div>
</section>
