---
import { asset } from '../utils';
const links = [
  { href: '#lineup',        label: 'Lineup' },
  { href: '#venue',         label: 'Venue' },
  { href: '#whats-on',      label: "What's On" },
  { href: '#accommodation', label: 'Stay' },
  { href: '#map',           label: 'Map' },
  { href: '#tickets',       label: 'Tickets' },
  { href: '#getting-there', label: 'Getting There' },
  { href: '#contact',       label: 'Contact' },
];


---

<nav
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 bg-lotg-dark/90 backdrop-blur-md border-b border-lotg-green/20 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-14">
    <!-- Logo wordmark -->
    <a href="#hero" class="font-frijole text-lotg-green text-lg leading-none hover:text-lotg-yellow transition-colors shrink-0">
      Lost in the Grass
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-5 text-sm tracking-wide">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class="text-lotg-offwhite hover:text-lotg-green transition-colors uppercase"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Tickets CTA (desktop) -->
    <a
      href="https://outtograss.com/product-category/lost-in-the-grass-2026"
      target="_blank"
      rel="noopener"
      class="hidden lg:inline-flex items-center gap-1 bg-lotg-green text-lotg-dark px-4 py-1.5 rounded-full text-sm uppercase font-bold hover:bg-lotg-yellow transition-colors shrink-0"
    >
      Get Tickets
    </a>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      class="lg:hidden flex flex-col justify-center gap-1.5 w-8 h-8 shrink-0"
    >
      <span class="hamburger-line block h-0.5 w-6 bg-lotg-offwhite rounded transition-all duration-300"></span>
      <span class="hamburger-line block h-0.5 w-6 bg-lotg-offwhite rounded transition-all duration-300"></span>
      <span class="hamburger-line block h-0.5 w-6 bg-lotg-offwhite rounded transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-lotg-dark border-t border-lotg-green/20"
  >
    <ul class="flex flex-col px-4 py-3 gap-0">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link block py-2.5 text-lotg-offwhite hover:text-lotg-green transition-colors uppercase tracking-wide border-b border-lotg-green/10 last:border-0"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-3 pb-1">
        <a
          href="https://outtograss.com/product-category/lost-in-the-grass-2026"
          target="_blank"
          rel="noopener"
          class="block text-center bg-lotg-green text-lotg-dark py-2.5 rounded-full uppercase font-bold hover:bg-lotg-yellow transition-colors"
        >
          Get Tickets
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const lines = toggle.querySelectorAll('.hamburger-line') as NodeListOf<HTMLElement>;

  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    // Animate to X
    if (open) {
      lines[0].style.transform = 'translateY(8px) rotate(45deg)';
      lines[1].style.opacity = '0';
      lines[2].style.transform = 'translateY(-8px) rotate(-45deg)';
    } else {
      lines[0].style.transform = '';
      lines[1].style.opacity = '';
      lines[2].style.transform = '';
    }
  });

  // Close on link click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      lines[0].style.transform = '';
      lines[1].style.opacity = '';
      lines[2].style.transform = '';
    });
  });
</script>
