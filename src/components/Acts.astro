---
import { billingRows, mainActs, djs } from '../data/site';
import { asset } from '../utils';

// Gradient classes for acts without photos (cycle through 6)
const gradients = [
  'card-gradient-1', 'card-gradient-2', 'card-gradient-3',
  'card-gradient-4', 'card-gradient-5', 'card-gradient-6',
];

// Headline font sizes for each billing row (desktop / mobile)
const rowSizes = [
  'text-4xl md:text-6xl lg:text-7xl',
  'text-3xl md:text-4xl lg:text-5xl',
  'text-2xl md:text-3xl lg:text-4xl',
  'text-xl  md:text-2xl lg:text-3xl',
  'text-lg  md:text-xl  lg:text-2xl',
];

let fallbackGradientIndex = 0;
---

<section id="lineup" class="bg-lotg-dark py-20 px-4 md:px-8 lg:px-16">
  <div class="max-w-7xl mx-auto">

    <!-- Section heading -->
    <div class="text-center mb-10">
      <p class="text-lotg-yellow text-lg tracking-widest uppercase mb-1">Echofields Presents</p>
      <h2 class="font-bangers text-lotg-green text-6xl md:text-8xl tracking-wider text-outline-lg leading-none">
        Lineup
      </h2>
    </div>

    <!-- Poster-style billing -->
    <div class="text-center border-y border-lotg-green/30 py-8 mb-14 space-y-2">
      {billingRows.map((row, rowIdx) => (
        <p class={`font-bangers text-lotg-offwhite tracking-wider leading-tight ${rowSizes[rowIdx]}`}>
          {row.join(' · ')}
        </p>
      ))}
      <p class="font-bangers text-lotg-offwhite/40 text-base tracking-widest mt-3">& MORE TBC…</p>
    </div>

    <!-- Act cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 mb-16">
      {mainActs.map(act => {
        const hasPhoto = Boolean(act.photo);
        const gradClass = hasPhoto ? '' : gradients[fallbackGradientIndex++ % gradients.length];

        return (
          <div class={`rounded-2xl overflow-hidden flex flex-col border border-lotg-green/20 hover:border-lotg-green/60 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_0_24px_rgba(98,212,32,0.2)] ${gradClass}`}>
            {/* Photo or illustrated fallback */}
            <div class="relative aspect-square overflow-hidden">
              {hasPhoto ? (
                <img
                  src={asset(act.photo!)}
                  alt={act.name}
                  class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center p-6">
                  <span class="font-bangers text-lotg-green text-3xl text-center leading-tight text-outline drop-shadow-lg">
                    {act.name}
                  </span>
                </div>
              )}
              {/* Style tag overlay */}
              {act.style && (
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-lotg-dark/90 to-transparent px-3 py-2">
                  <p class="text-lotg-yellow text-xs uppercase tracking-wide">{act.style}</p>
                </div>
              )}
            </div>

            {/* Card body */}
            <div class="p-4 flex flex-col gap-2 flex-1">
              {hasPhoto && (
                <h3 class="font-bangers text-lotg-green text-2xl tracking-wide leading-none">{act.name}</h3>
              )}
              {act.about && act.about !== 'More info coming soon.' && (
                <p class="text-lotg-offwhite/70 text-sm leading-snug flex-1">{act.about}</p>
              )}
              {act.about === 'More info coming soon.' && (
                <p class="text-lotg-offwhite/40 text-sm italic">More info coming soon</p>
              )}
              {act.spotify && (
                <a
                  href={act.spotify}
                  target="_blank"
                  rel="noopener"
                  class="mt-auto inline-flex items-center gap-2 text-lotg-green text-sm hover:text-lotg-yellow transition-colors"
                >
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.623.623 0 01-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 11-.277-1.215c3.809-.87 7.077-.496 9.712 1.115.294.18.387.565.207.857zm1.224-2.72a.78.78 0 01-1.072.257c-2.687-1.652-6.785-2.13-9.965-1.166a.78.78 0 11-.453-1.49c3.633-1.105 8.147-.57 11.234 1.327a.78.78 0 01.256 1.072zm.105-2.83C14.692 8.95 9.375 8.775 6.297 9.71a.937.937 0 11-.543-1.793c3.53-1.07 9.398-.864 13.101 1.338a.937.937 0 01-.94 1.618z"/>
                  </svg>
                  Listen on Spotify
                </a>
              )}
            </div>
          </div>
        );
      })}
    </div>

    <!-- DJs section -->
    <div class="border-t border-lotg-green/30 pt-12">
      <h3 class="font-bangers text-lotg-yellow text-4xl md:text-5xl tracking-wider text-center mb-8">
        DJs
      </h3>
      <div class="flex flex-wrap justify-center gap-3">
        {djs.map(dj => (
          <div class="group relative">
            {dj.listen ? (
              <a
                href={dj.listen}
                target="_blank"
                rel="noopener"
                class="flex flex-col items-center bg-lotg-card border border-lotg-green/30 rounded-full px-5 py-2 hover:border-lotg-green hover:bg-lotg-green/10 transition-all duration-200"
              >
                <span class="font-bangers text-lotg-offwhite text-lg tracking-wide group-hover:text-lotg-green transition-colors">{dj.name}</span>
                <span class="text-lotg-offwhite/40 text-xs">{dj.location}</span>
              </a>
            ) : (
              <div class="flex flex-col items-center bg-lotg-card border border-lotg-green/20 rounded-full px-5 py-2">
                <span class="font-bangers text-lotg-offwhite text-lg tracking-wide">{dj.name}</span>
                <span class="text-lotg-offwhite/40 text-xs">{dj.location}</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
